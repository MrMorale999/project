{
  "compileOnSave": false,
  "compilerOptions": {
    "sourceMap": true,
    "declaration": false,
    "module": "es2020",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "target": "es2022",
    "useDefineForClassFields": false,
    "skipLibCheck": true,
    "typeRoots": [
      "node_modules/@types"
    ],
    "types": ["jasmine", "node"],
    "lib": [
      "es2022",
      "dom"
    ]
  },
  "exclude": [
    "node_modules"
  ]
}
